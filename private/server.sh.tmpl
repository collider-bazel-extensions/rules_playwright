#!/usr/bin/env bash
# Wrapper for playwright_server (npx playwright run-server).
set -euo pipefail

if [[ -z "${RUNFILES_DIR:-}" ]]; then
  if [[ -d "${0}.runfiles" ]]; then RUNFILES_DIR="${0}.runfiles"
  elif [[ -d "$(dirname "$0").runfiles" ]]; then RUNFILES_DIR="$(dirname "$0").runfiles"
  fi
  export RUNFILES_DIR
fi

exec "${RUNFILES_DIR}/_main/{LAUNCHER}" --mode server --port "{PORT}"
